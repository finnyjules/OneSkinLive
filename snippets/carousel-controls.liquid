{%- comment -%}
  Carousel prev/next arrow buttons
  Usage: {% render 'carousel-controls', id: 'shade-compare' %}
{%- endcomment -%}

<button class="carousel-nav-btn carousel-nav-btn--prev" data-carousel-prev="{{ id }}" aria-label="Previous">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M15 18l-6-6 6-6"/>
  </svg>
</button>
<button class="carousel-nav-btn carousel-nav-btn--next" data-carousel-next="{{ id }}" aria-label="Next">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M9 18l6-6-6-6"/>
  </svg>
</button>
