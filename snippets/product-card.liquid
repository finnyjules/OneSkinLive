{%- comment -%}
  Reusable product card for cross-sell and gift sections
  Usage: {% render 'product-card', product: product, show_rating: true, badge: 'Best-seller' %}
{%- endcomment -%}

<div class="product-card">
  <div class="product-card__image-wrapper">
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 300 }}"
        alt="{{ product.featured_image.alt | escape }}"
        width="300"
        height="400"
        loading="lazy"
        class="product-card__image"
      >
    {%- else -%}
      <div class="product-card__image-placeholder"></div>
    {%- endif -%}

    {%- if badge -%}
      <span class="product-card__badge pill" style="background: var(--color-primary);">{{ badge }}</span>
    {%- endif -%}
  </div>

  <div class="product-card__info">
    <h3 class="product-card__title">{{ product.title }}</h3>
    <p class="product-card__description">{{ product.description | strip_html | truncatewords: 10 }}</p>

    {%- if show_rating -%}
      <div class="product-card__rating">
        {% render 'star-rating', rating: 4.7, size: 12 %}
        <span class="product-card__rating-number">4.7</span>
      </div>
    {%- endif -%}

    <button class="btn-outline product-card__add-to-cart" type="button">
      <span>Add TO CART</span>&nbsp;&nbsp;<strong>{{ product.price | money }}</strong>
    </button>
  </div>
</div>
